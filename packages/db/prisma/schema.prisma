generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  photo      String?
  googleId   String?
  facebookId String?
  githubId   String?
  sites      site[]
}

model site {
  id                  String     @id @default(uuid())
  userid              String
  primeRegionId       String     @default("04c66f73-92fe-4794-ae20-b81e271590b9")
  url                 String
  timeAdded           DateTime   @default(now())
  intervalTime        Int
  body                Json?
  header              Json?
  method              String     @default("GET")
  timeout             Int        @default(5000)
  followRedirect      Boolean    @default(true)
  sslVerify           Boolean    @default(true)
  maintenanceDays     days[]     @default([])
  maintenanceEndMin   Int?
  maintenanceStartMin Int?
  incidents           Incident[]
  user                User       @relation(fields: [userid], references: [id])
}

model Region {
  id   String @id @default(uuid())
  name String @unique
}

model Incident {
  id              String    @id @default(uuid())
  siteId          String
  startedAt       DateTime
  resolvedAt      DateTime?
  durationSeconds Int?
  site            site      @relation(fields: [siteId], references: [id])

  @@index([siteId, startedAt(sort: Desc)])
}

enum siteStatus {
  Up
  Down
  Unknown
  Warning
}

enum days {
  Sunday
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
}
