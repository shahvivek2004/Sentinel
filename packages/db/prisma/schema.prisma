generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  photo      String?
  googleId   String?
  facebookId String?
  githubId   String?
  sites      site[]
}

model site {
  id                  String       @id @default(uuid())
  userid              String
  url                 String
  intervalTime        Int
  timeAdded           DateTime     @default(now())
  method              String       @default("GET")
  timeout             Int          @default(5000)
  body                Json?
  header              Json?
  sslVerify           Boolean      @default(true)
  followRedirect      Boolean      @default(true)
  maintenanceStartMin Int?
  maintenanceEndMin   Int?
  maintenanceDays     days[]       @default([])
  user                User         @relation(fields: [userid], references: [id])
  ticks               tickStatus[]
}

model Region {
  id    String       @id @default(uuid())
  name  String       @unique
  ticks tickStatus[]
}

model tickStatus {
  id               String     @id @default(uuid())
  region_id        String
  site_id          String
  createdAt        DateTime   @default(now())
  status           siteStatus
  response_time_ms Int
  statusCode       Int?
  errorType        String?
  errorReason      String?
  region           Region     @relation(fields: [region_id], references: [id])
  site             site       @relation(fields: [site_id], references: [id])
}

enum siteStatus {
  Up
  Down
  Warning
  Unknown
}

enum days {
  Sunday
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
}
